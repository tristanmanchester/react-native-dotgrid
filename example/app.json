{
  "expo": {
    "name": "Dotgrid Example",
    "slug": "dotgrid-example",
    "version": "1.0.0",
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "orientation": "portrait",
    "platforms": ["ios", "android", "web"],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.tmanchester.dotgrid-example"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    }
  }
}
