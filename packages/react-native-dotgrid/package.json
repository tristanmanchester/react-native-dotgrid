{
  "name": "react-native-dotgrid",
  "version": "0.3.0",
  "description": "Animated dot-matrix display component for React Native using Skia, Reanimated, and an optional SVG fallback.",
  "keywords": [
    "react-native",
    "react-native-skia",
    "react-native-svg",
    "reanimated",
    "dot-matrix",
    "matrix",
    "led",
    "animation",
    "visualization",
    "vu-meter",
    "expo",
    "expo-go",
    "canvas"
  ],
  "author": "Tristan Manchester",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tristanmanchester/react-native-dotgrid"
  },
  "bugs": {
    "url": "https://github.com/tristanmanchester/react-native-dotgrid/issues"
  },
  "homepage": "https://github.com/tristanmanchester/react-native-dotgrid#readme",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "react-native": "dist/esm/index.js",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "react-native": "./dist/esm/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "build:cjs": "tsc -p tsconfig.build.cjs.json",
    "build:esm": "tsc -p tsconfig.build.esm.json",
    "build:esm:package": "node scripts/write-esm-package-json.js",
    "build:types": "tsc -p tsconfig.build.types.json",
    "build": "npm run clean && npm run build:cjs && npm run build:esm && npm run build:esm:package && npm run build:types",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "dev:pack": "bash ../../scripts/pack-and-run-example.sh",
    "smoke:pack": "bash ../../scripts/smoke-test-packed-example.sh",
    "generate:demos": "node scripts/generate-demos.js all",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=2.2.12",
    "react": ">=19.0.0",
    "react-native": ">=0.80.0",
    "react-native-reanimated": ">=4.1.0",
    "react-native-svg": ">=14.0.0",
    "react-native-worklets": ">=0.5.1"
  },
  "peerDependenciesMeta": {
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-typescript": "^7.25.0",
    "@react-native/eslint-config": "^0.74.0",
    "@shopify/react-native-skia": "^2.2.12",
    "@testing-library/jest-native": "^5.0.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.5",
    "@types/react": "^19.0.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "canvas": "^3.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.6.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "4.1.3",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "react-test-renderer": "19.1.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
