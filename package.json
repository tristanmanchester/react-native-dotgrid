{
  "name": "react-native-dotgrid-workspace",
  "private": true,
  "workspaces": [
    "example",
    "packages/react-native-dotgrid"
  ],
  "scripts": {
    "build": "npm run build -w react-native-dotgrid",
    "typecheck": "npm run typecheck -w react-native-dotgrid",
    "test": "npm run test -w react-native-dotgrid -- --runInBand",
    "example:web": "npm run web -w dotgrid-example",
    "example:ios": "npm run ios -w dotgrid-example",
    "smoke:pack": "bash ./scripts/smoke-test-packed-example.sh",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "overrides": {
    "@shopify/react-native-skia": "2.2.12",
    "expo": "$expo",
    "expo-asset": "12.0.12",
    "react": "19.1.0",
    "react-test-renderer": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "4.1.3",
    "react-native-svg": "15.12.1",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.5.1"
  },
  "version": "1.0.0",
  "dependencies": {
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
